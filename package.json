{
  "name": "kivo",
  "version": "1.4.1",
  "type": "module",
  "repository": "https://gitlab.com/imapps/kivo.git",
  "author": "Igor Siergiej <igorsiergiej@gmail.com>",
  "scripts": {
    "start": "bun --hot src/index.ts",
    "build": "bun build src/index.ts --outdir build --target=bun --external bcryptjs --external mongodb",
    "lint": "biome check .",
    "lint:fix": "biome check --fix --unsafe .",
    "format": "biome format --write .",
    "prepare": "husky || true",
    "release": "semantic-release"
  },
  "dependencies": {
    "@imapps/api-utils": "^0.3.0",
    "bcryptjs": "^3.0.2",
    "jsonwebtoken": "^9.0.2",
    "koa": "^2.16.0",
    "koa-body": "^6.0.1",
    "koa-cors": "^0.0.16",
    "koa-helmet": "^6.0.0",
    "koa-logger": "^3.2.1",
    "koa-ratelimit": "^5.0.1",
    "koa-router": "^13.0.1",
    "mongodb": "^6.13.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.5",
    "@imapps/biome-config": "^0.3.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "latest",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/koa": "^2.15.0",
    "@types/koa-cors": "^0.0.6",
    "@types/koa-helmet": "^6.0.6",
    "@types/koa-logger": "^3.1.5",
    "@types/koa-ratelimit": "^5.0.5",
    "@types/koa-router": "^7.4.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.0",
    "semantic-release": "^24.2.0"
  },
  "lint-staged": {
    "*.{ts,mts,cts}": [
      "biome check --fix --unsafe ."
    ]
  },
  "module": "src/index.ts",
  "private": true
}
