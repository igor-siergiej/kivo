{
  "name": "kivo",
  "version": "1.8.1",
  "type": "module",
  "repository": "https://github.com/igor-siergiej/kivo",
  "author": "Igor Siergiej <igorsiergiej@gmail.com>",
  "scripts": {
    "start": "bun --hot src/index.ts",
    "build": "bun build src/index.ts --outdir build --target=bun --external bcryptjs --external mongodb",
    "test": "bun test",
    "lint": "biome check .",
    "lint:fix": "biome check --fix --unsafe .",
    "format": "biome format --write .",
    "prepare": "husky || true",
    "release": "semantic-release"
  },
  "dependencies": {
    "@imapps/api-utils": "0.6.0",
    "bcryptjs": "^3.0.2",
    "hono": "^4.6.14",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.13.1",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.5",
    "@imapps/biome-config": "0.5.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "^1.1.14",
    "@types/jsonwebtoken": "^9.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.0",
    "semantic-release": "^24.2.0"
  },
  "lint-staged": {
    "*.{ts,mts,cts,json}": "biome check --fix --unsafe"
  },
  "module": "src/index.ts",
  "private": true
}
